    $(function () {
        var item_max_fields = 4; //maximum input boxes allowed

        var x = @Model.MeetingRequirements.Count; //initial text box count; //initial text box count
        $("#itemDiv").on("click", "#addItemField", function (e) {//on add input button click
            e.preventDefault();
            if (x < item_max_fields) { //max input box allowed
                $("#itemDiv").append(
                    `<div class="row">
                        <div class="col-4">
                            <input name="MeetingRequirements[`+ x + `].ItemName" asp-for="MeetingRequirements[` + x + `].ItemName" type="text" class="form-control form-control-border border-width-2" placeholder="Item Name">
                            <span class="text-danger" data-valmsg-for= "MeetingRequirements[`+ x + `].ItemName" data-valmsg-replace="true"></span>
                        </div>
                        <div class="col-3">
                            <a class="btn btn-default" id = "addExternalAttendeeField">
                                <i class="fas fa-plus"></i>
                            </a>
                            <a class="btn btn-default" id = "removeItemField">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </div>`
                ); //add input box
                x++; //text box increment

            }
        });

        $("#form").removeData("validator").removeData("unobtrusiveValidation");
        $.validator.unobtrusive.parse('#form');
        $("#itemDiv").on("click", "#removeItemField", function (e) { //user click on remove text
            e.preventDefault();
            if (x > 1) {
                $(this).parent('div').parent('div').remove();
                x--;
            }
            else {
                $(this).parent('div').parent('div').remove();
                x--;
                $("#itemDiv").append(
                    `<div class="row">
                        <div class="col-4">
                            <input name="MeetingRequirements[`+ x + `].ItemName" asp-for="MeetingRequirements[` + x + `].ItemName" type="text" class="form-control form-control-border border-width-2" placeholder="Item Name">
