                        </div>
                        <div class="col-3">
                            <a class="btn btn-default" id = "addItemField">
                                <i class="fas fa-plus"></i>
                            </a>
                            <a class="btn btn-default" id = "removeItemField">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </div>`
                );
                x++;
            }
        })
    });

    $(function () {

        $('input[type="radio"]').on('change', function () {
            if ($(this).attr("value") == "@((char)LocationType.FaceToFace)") {
                $("#MeetingLink").prop('required', false);
                $("#MeetingLink").hide();
                $("#MeetingRoomDdl").prop('required', true);
                $("#MeetingRoomDdl").show();

            }

            if ($(this).attr("value") == "@((char)LocationType.Online)") {
                $("#MeetingRoomDdl").prop('required', false);
                $("#MeetingRoomDdl").hide();
                $("#MeetingLink").prop('required', true);
                $("#MeetingLink").show();
            }

            if ($(this).attr("value") == "@((char)LocationType.Both)") {
                $("#MeetingRoomDdl").show();
                $("#MeetingLink").show();
                $("#MeetingRoomDdl").prop('required', true);
                $("#MeetingLink").prop('required', true);
                }
        });

        var value = "@(Model.MeetingLocation)";
        $("input[type='radio'][value=" + value + "]").trigger('click');


    })
</script>
