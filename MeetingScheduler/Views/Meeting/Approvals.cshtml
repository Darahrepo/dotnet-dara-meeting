@model List<MeetingScheduler.UI.Models.MeetingVm>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer localizer
@inject Microsoft.Extensions.Localization.IStringLocalizer<MeetingScheduler.UI.SharedResource> sharedLocalizer
@using MeetingScheduler.Domain.Enums;
@using System.Globalization;
@{
    ViewData["Title"] = @localizer["Title"];
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="info-box transparent">
        <span class="info-box-icon bg-info"><i class="far fa-calendar-alt"></i></span>
        <div class="info-box-content">
            <h1 class="m-0">@ViewData["Title"]</h1>
        </div>
    </div>
</div>

<form>
    <div>
        <!-- Main content -->
        <section class="content">
            <div class="container-fluid">
                <!-- Main row -->
                <div class="row">
                    <div class="col-sm-12">
                        <div class="card text-sm d-block">
                            <div class="overlay-wrapper">
                                <div class="overlay"><i class="fas fa-3x fa-spinner fa-pulse"></i><div class="text-bold pt-2"></div></div>
                            </div>
                            <div class="card-header ">

                                <button type="button" class="btn btn-outline-primary dropdown-toggle float-left" id="filter" data-toggle="dropdown">
                                    @localizer["ScheduledMeetings"]
                                </button>
                                <div class="dropdown-menu ">
                                    @*<a class="dropdown-item" href="#" id="GetPendingApprovals" onclick="GetPendingApprovals()">@localizer["PendingApprovals"]</a>
                                    <a class="dropdown-item" href="#" id="GetApprovedMeetingsToday" onclick="GetApprovedMeetingsToday()">@localizer["ApprovedMeetingsToday"]</a>*@
                                    <a class="dropdown-item" href="#" id="GetScheduledMeetings" onclick="GetScheduledMeetings()">@localizer["ScheduledMeetings"]</a>
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item" href="#" id="GetArchived" onclick="GetArchived()">@localizer["Archived"]</a>
                                </div>
                                <a asp-action="Create" class="btn btn-default btn-success float-right">@sharedLocalizer["CreateMeeting"]</a>
                            </div>

                            <!-- /.card-header -->
                            <div class="card-body" id="meeting-data">
                                <table id="example1" class="table table-bordered">
                                    <thead>
                                        <tr>
                                            <th> # </th>
                                            <th> @localizer["Subject"] </th>
                                            <th> @localizer["Host"] </th>
                                            <th> @localizer["DateTime"] </th>
                                            <th> @localizer["Place"] </th>
                                            <th> @localizer["Status"] </th>
                                           @*  @if (User.IsInRole(Roles.Admin))
                                            {
                                                <th> @localizer["Reason"] </th>
                                            } *@
                                            <th> @localizer["Actions"] </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ var count = 0; }
                                        @foreach (var item in Model.Select((value, index) => new { value, index }))
                                        {
                                            <tr>
                                                <td> @(++count) </td>
                                                <td> <p> @item.value.Subject </p> </td>
                                                <td> <p> @item.value.Host.DisplayName</p> </td>
                                                <td> <p> @item.value.Date.ToString("dd MMMM yyyy") <br />  @item.value.Time_From.ToString("hh\\:mm") - @item.value.Time_To.ToString("hh\\:mm") </p> </td>

                                                <td>
                                                    @if (item.value.MeetingLocationType == LocationType.Online)
                                                    {
                                                        <p>
                                                            <b>  @localizer["Online"] </b> <br />
                                                            @if (!string.IsNullOrWhiteSpace(item.value.MeetingLink))
                                                            {
                                                                <a target ="_blank" href="@(item.value.MeetingLink)">@localizer["MeetingLink"]  </a>
                                                            }
                                                            else
                                                            {
                                                                <code> @localizer["NoMeetingLink"] </code>
                                                            }

                                                        </p>
                                                    }
                                                    else if (item.value.MeetingLocationType == LocationType.FaceToFace)
                                                    {
                                                        <p>
                                                            <b> @localizer["FaceToFace"] </b> <br />
                                                            @item.value.MeetingRoom.NameEn - @item.value.MeetingRoom.NameAr
                                                        </p>
                                                    }
                                                    else if (item.value.MeetingLocationType == LocationType.Both)
                                                    {
                                                        <input hidden id="meetingType" value="LocationType.Both" />
                                                        <p>
                                                            <b> @localizer["Both"] </b>
                                                            <br />
                                                            @item.value.MeetingRoom.NameEn - @item.value.MeetingRoom.NameAr
                                                            <br />
                                                            @if (!string.IsNullOrWhiteSpace(item.value.MeetingLink))
                                                            {
                                                                <a target="_blank" href="@(item.value.MeetingLink)">@localizer["MeetingLink"]  </a>
                                                            }
                                                            else
                                                            {
                                                                <code> @localizer["NoMeetingLink"] </code>
                                                            }
                                                        </p>
                                                    }
                                                </td>
                                                <td>
                                                    @if (item.value.ApprovalStatus == ApprovalStatus.Approved)
                                                    {
                                                        <span class="badge badge-success">@sharedLocalizer["Approved"]</span>
                                                    }
                                                    else if (item.value.ApprovalStatus == ApprovalStatus.Pending)
                                                    {
                                                        <span class="badge badge-warning"> @sharedLocalizer["Pending"]</span>
                                                    }
                                                    else if (item.value.ApprovalStatus == ApprovalStatus.Cancelled)
                                                    {
                                                        <span class="badge badge-danger">@sharedLocalizer["Cancelled"]  </span>
                                                    }
                                                    else if (item.value.ApprovalStatus == ApprovalStatus.Rejected)
                                                    {
                                                        <span class="badge badge-danger"> @sharedLocalizer["Rejected"] </span>
                                                    }
                                                </td>
                                              @*   <td>
                                                    @if (item.value.ApprovalStatus == ApprovalStatus.Pending && (item.value.Date > DateTime.Now.Date || (item.value.Date == DateTime.Now.Date && item.value.Time_From.Ticks > DateTime.Now.TimeOfDay.Ticks)) && User.IsInRole(Roles.Admin))
                                                    {
                                                        <textarea rows="3" class="reason form-control" placeholder="@localizer["Reason"]" style="min-height: 78px; max-height:110px "></textarea>
                                                        <span class="text-danger" id="error-message[@(item.index)]"></span>
                                                    }
                                                    else if (item.value.ApprovalStatus == ApprovalStatus.Rejected || item.value.ApprovalStatus == ApprovalStatus.Approved)
                                                    {
                                                        <p>@item.value.Reason</p>
                                                    }
                                                </td> *@
                                                <td>
                                                    <a class="btn btn-outline-dark btn-sm" data-toggle="modal" data-backdrop="static" data-keyboard="false" data-target="#detailsModal" data-id="@item.value.Id" onclick="Details(@item.value.Id)">
                                                        <i class="fas fa-eye"></i>
                                                        @localizer["View"]
                                                    </a>

                                                    @if ((item.value.Date > DateTime.Now.Date || (item.value.Date == DateTime.Now.Date && item.value.Time_From.Ticks > DateTime.Now.TimeOfDay.Ticks)) && item.value.ApprovalStatus == ApprovalStatus.Pending)
                                                    {
                                                        <a class=" btn btn-outline-success btn-sm "    onclick='changeApprovalStatus(this)'  data-status="@ApprovalStatus.Approved" data-id="@item.value.Id" data-index="@item.index">
                                                            <i class="fas fa-check">
                                                            </i>
                                                            @localizer["Approve"]
                                                        </a>
                                                        <a class=" btn btn-outline-danger btn-sm"  onclick='changeApprovalStatus(this)'  data-status="@ApprovalStatus.Rejected" data-id="@item.value.Id" data-index="@item.index">
                                                            <i class="fas fa-times">
                                                            </i>
                                                            @localizer["Reject"]
                                                        </a>
                                                    }
                                                    @if((item.value.Date > DateTime.Now.Date || (item.value.Date == DateTime.Now.Date && item.value.Time_From.Add(TimeSpan.FromMinutes(15)).Ticks > DateTime.Now.TimeOfDay.Ticks))
                                                    && (item.value.ApprovalStatus == ApprovalStatus.Pending || item.value.ApprovalStatus == ApprovalStatus.Approved))
                                                    {
                                                        <a class="btn btn-outline-danger btn-sm "   onclick='changeApprovalStatus(this)'  data-status="@ApprovalStatus.Cancelled" data-id="@item.value.Id" data-index="@item.index" >
                                                            <i class="fas fa-trash">
                                                            </i>
                                                            @localizer["Cancel"]
                                                        </a>

                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <!-- /.card-body -->
                        </div>
                        <!-- /.card -->
                    </div>
                </div>
                <!-- /.row (main row) -->
            </div> <!-- /.container-fluid -->
        </section>
        <!-- /.content -->
    </div>
</form>

<div class="modal fade" id="detailsModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="overlay-wrapper">
                <div class="overlay"><i class="fas fa-3x fa-spinner fa-pulse"></i><div class="text-bold pt-2"></div></div>
            </div>
            <div class="modal-header">
                <h4 class="modal-title">
                    @localizer["Details"]
                </h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="@sharedLocalizer["Close"]">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div></div>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-outline-danger btn-default" data-dismiss="modal"> @sharedLocalizer["Close"]</button>
            </div>
        </div>
    </div>
</div>


@section Scripts{
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}


