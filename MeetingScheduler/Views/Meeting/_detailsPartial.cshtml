@model MeetingScheduler.UI.Models.MeetingVm
@using MeetingScheduler.Domain.Enums;
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer localizer
@inject Microsoft.Extensions.Localization.IStringLocalizer<MeetingScheduler.UI.SharedResource> sharedLocalizer
@using System.Globalization;
@using System.Security.Claims;
@{
    Layout = "";
    var culture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
}

<script src="~/js/site.js"></script>

<!-- Toastr -->
<link rel="stylesheet" href="~/plugins/toastr/toastr.min.css">

<!-- SweetAlert2 -->
<link rel="stylesheet" href="~/plugins/sweetalert2-theme-bootstrap-4/bootstrap-4.min.css">

<div class="container-fluid">
    <div class="float-right">

        @if (Model.ApprovalStatus == ApprovalStatus.Approved)
        {
            <span class="badge badge-success"> @localizer["Approved"]  </span>
        }
        else if (Model.ApprovalStatus == ApprovalStatus.Cancelled)
        {
            <span class="badge badge-danger">  @localizer["Cancelled"] </span>
        }

        @if (Model.MeetingLocationType == LocationType.Online)
        {
            <span class="badge badge-warning">  @localizer["Online"] </span>
            @if (Model.IsWebex)
            {
                <span class="badge badge-dark">  Webex </span>
            }
            else
            {
                <span class="badge badge-primary">  Zoom </span>
            }
        } else if( Model.MeetingLocationType == LocationType.FaceToFace ){
             <span class="badge badge-warning">  @localizer["FaceToFace"] </span>
        }
        else
        {
            <span class="badge badge-warning">  @localizer["Both"] </span>
            @if (Model.IsWebex)
            {
                <span class="badge badge-dark">  Webex </span>
            }
            else
            {
                <span class="badge badge-primary">  Zoom </span>
            }
        }

        @if (Model.ZoomAccount == ZoomUserType.Ceo)
        {
            <span class="badge badge-warning">  @sharedLocalizer["CeoMeeting"] </span>
        }
       
    </div>
    <div class="row">
        <div class="float-right">


            @if (Model.IsRecorded)
            {
                <span class="badge badge-success"><i class="fas fa-video"></i> @localizer["RecordingRequested"]  </span>
            }
            else
            {
                <span class="badge badge-danger"><i class="fas fa-video"></i>  @localizer["RecordingNotRequested"] </span>
            }


            @if(Model.IsAttachmentShared)
            {
                <span class="badge badge-success"><i class="fa fa-paperclip" aria-hidden="true"></i>&nbsp;&nbsp; @localizer["SharedAttachments"]  </span>
            }
            else
            {
                <span class="badge badge-danger"><i class="fa fa-paperclip" aria-hidden="true"></i>&nbsp;&nbsp; @localizer["PrivateAttachments"] </span>
            }
        </div>


        <div class="col-12 col-md-12 col-lg-8 order-1 order-md-1">

            <div class="text-muted">
                <b>@localizer["MeetingSubject"]</b>
                <div class="row">
                    <p class="text-sm d-block col-6">@Model.Subject</p>
                </div>
            </div>

            <div class="text-muted">
                <b>@localizer["MeetingHost"]</b>
                <div class="row">
                    <p class="col-6 text-sm d-block">@Model.Host.DisplayName</p>
                    <p class="col-6 text-sm d-block">@Model.Host.EmailAddress </p>

                </div>
            </div>

            <div class="text-muted">
                <b>@localizer["InternalAttendees"]</b>
                <div>
                    @{ if (Model.MeetingInternalAttendees.Count > 0)
                        {
                            int count = 1;
                            @foreach (var attendee in Model.MeetingInternalAttendees)
                            {
                                <div class="row">
                                    <p class="col-1 text-sm d-block"><b>@(count++)</b></p>
                                    <p class="col-5 text-sm d-block">@attendee.DisplayName</p>
                                    <p class="col-5 text-sm d-block">@attendee.EmailAddress </p>
                                </div>
                            }
                        }
                        else
                        {
                            <code>@localizer["None"]</code>
                        }
                    }
                </div>
            </div>


            <div class="text-muted">
                <b> @localizer["ExternalAttendees"] </b>
                <div>
                    @{
                        if (Model.ExternalAttendeesList.Count > 0)
                        {
                            int count = 1;
                            @foreach (var attendee in Model.ExternalAttendeesList)
                            {
                                <div class="row">
                                    <p class="col-1 text-sm d-block"><b>@(count++))</b></p>
                                    <p class="col-5 text-sm d-block">@attendee.NameAr <br /><span> @attendee.NameEn </span> 
                                    </p>
                                    <p class="col-5 text-sm d-block">@attendee.EmailAddress </p>
                                </div>
                            }
                        }
                        else
                        {
                            <code>@localizer["None"]</code>
                        }
                    }
                </div>
            </div>


            <div class="text-muted">
                <b>@localizer["Place"]</b>
                <div>
                    @if (Model.MeetingLocationType == LocationType.Online)
                    {
                        <div>
                            <p class="text-sm d-block">
                                [@localizer["Online"]]
                                <br />
                                @if(!string.IsNullOrWhiteSpace(Model.MeetingLink) && Model.ApprovalStatus == ApprovalStatus.Approved)
                                {
                                    <a class="text-sm" target="_blank" href="@(Model.MeetingLink)">@localizer["MeetingLink"]</a>
                                    <i class="fas fa-copy"  title="copy نسخ" onclick="CopyUrl('@(Model.MeetingLink)','@culture')"></i>
                                    <span class="text-sm d-block"><b>@localizer["MeetingId"]:</b> @(Model.IsWebex ? Model.WebexMeetingNumber :  Model.MeetingId)</span>
                                    <span class="text-sm d-block"><b>@localizer["Password"]: </b> @Model.MeetingPassword</span>
                                }
                                else
                                {
                                    <code>@localizer["NoMeetingLink"]</code>
                                }
                            </p>
                        </div>
                    }
                    else if (Model.MeetingLocationType == LocationType.FaceToFace)
                    {
                        <div>
                            <p class="text-sm d-block">
                                [@localizer["FaceToFace"]]
                                <br />
                                @Model.MeetingRoom.NameEn - @Model.MeetingRoom.NameAr
                            </p>
                        </div>
                    }
                    else if (Model.MeetingLocationType == LocationType.Both)
                    {
                        <div>
                            <p class="text-sm d-block">
                                [@localizer["Both"]]
                                <br />
                                @Model.MeetingRoom.NameEn - @Model.MeetingRoom.NameAr
                                <br />
                                @if (!string.IsNullOrWhiteSpace(Model.MeetingLink) && Model.ApprovalStatus == ApprovalStatus.Approved)
                                {
                                    <a class="text-sm" target="_blank" href="@(Model.MeetingLink)">@localizer["MeetingLink"]</a>
                                    <span class="right copyUrl badge badge-info" onclick="CopyUrl('@(Model.MeetingLink)','@culture')">
                                        <i class="fas fa-copy "> </i>
                                        <br /> @sharedLocalizer["Copy"]
                                    </span>
                                    <table>
                                        <tbody>
                                            <tr>
                                                <td><b>@localizer["MeetingId"]:</b></td>
                                                @if(Model.IsWebex){
                                                     <td> @Model.WebexMeetingNumber </td>
                                                }
                                                else
                                                {
                                                    <td> @Model.MeetingId</td>
                                                }
                                            </tr>
                                            <tr>
                                                <td><b>@localizer["Password"]:</b></td>
                                                <td> @Model.MeetingPassword</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <code>@localizer["NoMeetingLink"]</code>
                                }
                            </p>
                        </div>

                    }
                </div>
            </div>

            <div class="text-muted">
                <b class="mt-5 text-muted">@localizer["MeetingRequirements"]  </b>
                <div>
                    @{ if (Model.MeetingRequirements.Count > 0)
                        {
                            int count = 1;
                            <div class="row">
                                @foreach (var req in Model.MeetingRequirements)
                                {
                                    <p class="col-1 text-sm d-block"><b>@(count++)</b></p>
                                    <p class="col-5 text-sm d-block">@req.ItemName</p>
                                }
                            </div>
                        }
                        else
                        {

                            <code>@localizer["None"]</code>
                        }
                    }
                </div>
            </div>


            <div class="text-muted">
                @if (!string.IsNullOrWhiteSpace(Model.MeetingAgenda))
                {
                    <a id="printAgenda" class="btn btn-default btn-sm  float-right">
                        <i class="fas fa-print"></i>
                    </a>
                }
                <b class="mt-5 text-muted">
                    @localizer["MeetingAgenda"]
                </b>
                <div>
                    @if (!string.IsNullOrWhiteSpace(Model.MeetingAgenda))
                    {
                        <div class="card-body p-0" id="MeetingAgenda">
                            @Html.Raw(@Model.MeetingAgenda)
                        </div>
                    }
                    else
                    {

                        <code>@localizer["None"]</code>

                    }
                </div>
            </div>


        </div>


        <div class="col-12 col-md-12 col-lg-4 order-1 order-md-1">
            <div class="text-muted">
                <b>@localizer["DateTime"]</b>
                <p class="text-sm d-block">
                    @Model.Date.ToString("dd MMMM yyyy")
                    <br />
                    @Model.Time_From.ToString("hh\\:mm") - @Model.Time_To.ToString("hh\\:mm")
                </p>
            </div>

            <div class="text-muted">
                <b>@localizer["MeetingFiles"]</b>
                @{
                    if (Model.MeetingAttachments != null && Model.MeetingAttachments.Count > 0)
                    {
                        <ul class="list-unstyled">
                            @foreach (var attachment in Model.MeetingAttachments)
                            {
                                <li>
                                    <a href="@Url.Content($"~/{attachment.FilePath}")" target="_blank" class="btn-link text-secondary text-sm d-block" title="@Html.Encode(attachment.FileName)">
                                        <i class="fa fa-file-download"></i>
                                        @attachment.FileName
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div>
                            <code>@localizer["None"]</code>
                        </div>
                    }
                }
            </div>
        </div>



        @if ((Model.Date > DateTime.Now.Date || (Model.Date == DateTime.Now.Date && Model.Time_From.Ticks > DateTime.Now.TimeOfDay.Ticks)) && User.IsInRole(Roles.Admin) && Model.ApprovalStatus == ApprovalStatus.Pending)
        {
            <div class="text-muted col-12 col-md-12 col-lg-12 order-3 order-md-3">
                <div class="form-group">
                    <label>@localizer["Reason"]</label>
                    <textarea class="reason form-control" rows="3" maxlength="200" placeholder="@localizer["Reason"]" style="margin-top: 0px; margin-bottom: 0px; max-height: 200px;"></textarea>
                </div>
                <div>
                    <a class="btn btn-app bg-success float-right "   onclick='changeApprovalStatus(this)'  data-status="@ApprovalStatus.Approved" data-id="@Model.Id">
                        <i class="fas fa-check"></i> @localizer["Approve"]
                    </a>
                    <a class="btn btn-app bg-danger float-right "   onclick='changeApprovalStatus(this)'  data-status="@ApprovalStatus.Rejected" data-id="@Model.Id">
                        <i class="fas fa-times"></i> @localizer["Reject"]
                    </a>
                    <a class="btn btn-app bg-danger "   onclick='changeApprovalStatus(this)'  data-status="@ApprovalStatus.Cancelled" data-id="@Model.Id">
                        <i class="fas fa-trash"></i> @sharedLocalizer["Cancel"]
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="col-12 col-md-12 col-lg-8 order-1 order-md-1">
                <div class="text-muted">
                    <b>@localizer["Reason"]</b>
                    @if (!string.IsNullOrEmpty(Model.Reason))
                    {
                        <p class="text-sm d-block">
                            @Model.Reason
                        </p>
                    }
                    else
                    {
                        <div>
                            <code>@localizer["None"]</code>
                        </div>
                    }
                </div>
            </div>
            @if (Model.Date > DateTime.Now.Date || (Model.Date == DateTime.Now.Date && Model.Time_From.Add(TimeSpan.FromMinutes(15)).Ticks > DateTime.Now.TimeOfDay.Ticks) 
            && (Model.ApprovalStatus == ApprovalStatus.Pending || Model.ApprovalStatus == ApprovalStatus.Approved) 
            && (User.IsInRole(Roles.Admin) || Convert.ToInt32(User.FindFirst(ClaimTypes.PrimarySid).Value) == Model.HostId) || (Model.ZoomAccount == ZoomUserType.Ceo && (User.IsInRole(Roles.Ceo) || User.IsInRole(Roles.CeoAssistant))))
            {
                <div class="text-muted col-12 col-md-12 col-lg-12 order-3 order-md-3">
                    <div>
                        <a class="btn btn-app bg-danger float-right"   onclick='changeApprovalStatus(this)'  data-status="@ApprovalStatus.Cancelled" data-id="@Model.Id">
                            <i class="fas fa-trash"></i> @sharedLocalizer["Cancel"]
                        </a>
                    </div>
                </div>

            }
        }
    </div>
</div>

<script src="~/plugins/toastr/toastr.min.js"></script>
<script src="~/plugins/sweetalert2/sweetalert2.min.js"></script>


@section Scripts{
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}


<!-- Toastr -->
<script>

    $('#printAgenda').on('click', function (e) {
        var divToPrint = document.getElementById('MeetingAgenda');
        var popupWin = window.open('', '_blank');
        popupWin.document.write('<html><body onload="window.print()">' + divToPrint.innerHTML + '</html>');
        popupWin.document.close();
    });

    $(function () {
        $(".overlay").show();
        var Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000
        });
        $(".overlay").hide();
    });

</script>

