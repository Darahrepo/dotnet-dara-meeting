    <!-- Common Scripts -->

    @if ($"{TempData["message"]}" != "")
    {
        <script>
            $(function () {
                var Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000
                });
                var type = '@TempData["type"]';
                var message = '@TempData["message"]';
                toastr[type](message);
                               
               
            });
        </script>
    }


<script>

        var ROOT = '@Url.Content("~")';
        var controllerName = "@ViewContext.RouteData.Values["Controller"].ToString()";
        var hostHasConflictingMeeting = "@sharedLocalizer["HostHasConflictingMeeting"]";
        var hostHasConflictingWebinar = "@sharedLocalizer["HostHasConflictingWebinar"]";
        var conflictingTiming = "@sharedLocalizer["TimingNotAvailable"]";
        var attendeesNotChosen = "@sharedLocalizer["AttendeesNotChosen"]";
        var hoursTranslation = "@sharedLocalizer["hours"]";
        var minutesTranslation = "@sharedLocalizer["minutes"]";
        var dropFilesHere = "@sharedLocalizer["AddFiles"]";
        var similarLanguageError = "@sharedLocalizer["similarLanguageError"]";
        var PleaseInsertReason = "@sharedLocalizer["PleaseInsertReason"]";
        var swalTitle = "@sharedLocalizer["swalTitle"]";
        var swalText = "@sharedLocalizer["swalText"]";
        var swalConfirmButtonText = "@sharedLocalizer["swalConfirmButtonText"]";
        var swalCancelButtonText = "@sharedLocalizer["swalCancelButtonText"]";
        var preventSubmit = true;
        var timingAvailable = false;

        $(function () {

            var isArabic = '@CultureInfo.CurrentCulture.TextInfo.IsRightToLeft';
            var body = document.body;

            if (isArabic.toLowerCase() == 'true') {
                $("#example1").DataTable({
                "responsive": true,
                "lengthChange": false,
                "autoWidth": false,
                "language":
                {
                    "sProcessing": "جاري التحميل...",
                    "sLengthMenu": "أظهر مُدخلات _MENU_",
                    "sZeroRecords": "لم يُعثر على أية سجلات",
                    "sInfo": "إظهار _START_ إلى _END_ من أصل _TOTAL_ مُدخل",
                    "sInfoEmpty": "يعرض 0 إلى 0 من أصل 0 سجلّ",
                    "sInfoFiltered": "(منتقاة من مجموع _MAX_ مُدخل)",
                    "sInfoPostFix": "",
                    "sSearch": "ابحث:",
                    "sUrl": "",
                    "oPaginate": {
                        "sFirst": "الأول",
                        "sPrevious": "السابق",
                        "sNext": "التالي",
                        "sLast": "الأخير"
                    }
                },
                    "url": "//cdn.datatables.net/plug-ins/1.10.25/i18n/Arabic.json",
                }).buttons().container().appendTo('#example1_wrapper .col-md-6:eq(0)');

                if (isArabic.toLowerCase() == 'true') {
                    body.style.direction = "rtl";
                }

            }
            else {
                $("#example1").DataTable({
                    "responsive": true,
                    "lengthChange": false,
                    "autoWidth": false,
                    //"buttons": ["excel", "pdf", "print"] //, "colvis",
                }).buttons().container().appendTo('#example1_wrapper .col-md-6:eq(0)');

            }
        });

        $(function () {
            $('#example2').DataTable({
                "paging": true,
                "lengthChange": false,
                "searching": false,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
            });
        });

        function changeApprovalStatus(e) {
            $(".overlay").show();
            parentElm =  e.parentElement.nodeName;
            var reason = $(e).parent(parentElm).siblings(parentElm).find(".reason").val();// $(e).closest('[id]').find('#reason').val();

            var status = $(e).data('status');
            var id = $(e).data('id');

            if (status === "Rejected" && reason == '') {
                toastr.warning(PleaseInsertReason);
                toastr.options.fadeOut = 18000;
                $(".overlay").hide();
            }
            else {
                Swal.fire({
                    title: swalTitle,
                    icon: "warning",
                    html: swalText,
                    showCancelButton: true,
                    confirmButtonText: swalConfirmButtonText,
                    cancelButtonText: swalCancelButtonText,
                }).then(function (result) {
                    if (result.value) {
                        $.ajax({ //Submit the value of the drop_down
                            url: "/" + controllerName + "/ChangeApprovalStatus/",
                            type: "post",
                            data: { id: id, reason: reason, status: status },
                            success: function (response) {
                                if (response.type == 'success') {
                                    $(".overlay").hide();
                                    location.reload();
                                } else {
                                    toastr[response.type](response.message);
                                    toastr.options.fadeOut = 18000;
                                }
                                $(".overlay").hide();
                            }, error: function (response) {
                                $(".overlay").hide();
                                location.reload();
                            }
                        });
                    } else {
                        // handle cancel
                        $(".overlay").hide();
                    }
                });
            }
        }

</script>
    <script type="text/javascript" src="~/js/site.js"></script>


</body>
