@model MeetingScheduler.UI.Models.ItemVm

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div>
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <!-- Main row -->
            <div class="row">
                <div class="col-sm-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">DataTable with default features</h3>
                        </div>
                        <!--.card-header -->
                        <div class="card-body">
                            <form asp-controller="MeetingItem" asp-action="Edit" method="post">
                                <div class="card-body">
                                    <div class="form-group row">
                                        <label class="col-sm-2 col-form-label" asp-for="NameEn">Name in English</label>
                                        <input type="text" class="col-sm-10 form-control" asp-for="NameEn" placeholder="Name In English">
                                        <span class="text-danger" asp-validation-for="NameEn"></span>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-sm-2 col-form-label" asp-for="NameAr">Name in Arabic</label>
                                        <input type="text" class="col-sm-10 form-control" asp-for="NameAr" placeholder="Name In Arabic">
                                        <span class="text-danger" asp-validation-for="NameAr"></span>
                                    </div>
                                </div>
                                <div class="card-footer">
                                    <button type="submit" class="btn btn-info">Submit</button>
                                    <a asp-action="Index" class="btn btn-default float-right">Cancel</a>
                                </div>
                            </form>
                        </div>

                        <!-- /.card-body -->
                    </div>
                    <!-- /.card -->
                </div>
            </div>
            <!-- /.row (main row) -->
        </div><!-- /.container-fluid -->
    </section>
    <!-- /.content -->
</div>

@section Scripts{
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
