@model MeetingScheduler.UI.Models.LoginVm
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer localizer
@using System.Globalization

@{
    Layout = "";
    var culture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
}
<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@localizer["DarahMeetingScheduler"] | @localizer["SignIn"]</title>

    <!-- Google Font: Source Sans Pro -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css">
    <!-- icheck bootstrap -->
    <link rel="stylesheet" href="~/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
    @if (CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        <link rel="stylesheet" href="~/dist/css/rtl/adminlte.css">
        <!-- Bootstrap 4 RTL -->
        <link href="~/lib/bootstrap/dist/css/rtl/bootstrap.min.css" rel="stylesheet" />
        //<link rel="stylesheet" href="https://cdn.rtlcss.com/bootstrap/v4.2.1/css/bootstrap.min.css">
        <!-- Custom style for RTL -->
        <link rel="stylesheet" href="~/dist/css/rtl/custom.css">

    }
    else
    {
        <link rel="stylesheet" href="~/dist/css/adminlte.css">
    }
</head>
<body class="hold-transition login-page">
    <div class="login-box">
        <div class="login-logo">
            <a href="~/"><b>@localizer["DarahMeetingScheduler"]</b></a>
        </div>
        <!-- /.login-logo -->
        <div class="card">
            <div class="card-body login-card-body">
                <p class="login-box-msg">@localizer["SigninwithyourDarahUser"]</p>

                <span class="text-sm d-block text-danger" asp-validation-for="RememberMe"></span>
                <form asp-controller="Account" asp-action="Login" method="post">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" asp-for="Username" placeholder="@localizer["EmailAddress"]">
                        <div class="input-group-append">
                            <div class="input-group-text">
                                <span class="fas fa-envelope"></span>
                            </div>
                        </div>
                    </div>
                    @*<span class="text-danger" asp-validation-for="Username"></span>*@
                    <div class="input-group mb-3">
                        <input type="password" class="form-control" asp-for="Password" placeholder="@localizer["Password"]">
                        <div class="input-group-append">
                            <div class="input-group-text">
                                <span class="fas fa-lock"></span>
                            </div>
                        </div>

                    </div>
                    <div class="row">
                        <!-- /.col -->
                        <div class="col-4">
                            <button type="submit" class="btn btn-primary btn-block">@localizer["SignIn"]</button>
                        </div>
                        <!-- /.col -->
                    </div>
                </form>
            </div>
            <!-- /.login-card-body -->
        </div>
    </div>

    @section Scripts{
        @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }

    <!-- /.login-box -->
    <!-- jQuery -->
    <script src="~/plugins/jquery/jquery.min.js"></script>
    <!-- Bootstrap 4 -->
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>

    <script src="~/dist/js/adminlte.js"></script>

</body>
</html>
