@model MeetingScheduler.UI.Models.EmployeeVm
@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="info-box transparent">
        <span class="info-box-icon bg-info"><i class="fa fa-user-plus"></i></span>
        <div class="info-box-content">
            <h1 class="m-0">@ViewData["Title"]</h1>
        </div>
    </div>
</div>

<div>
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <!-- Main row -->
            <div class="row">
                <div class="col-sm-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">DataTable with default features</h3>
                        </div>
                        <!-- /.card-header -->
                        <div class="card-body">
                            <form asp-controller="Employee" asp-action="Create" method="post">
                                <div class="card-body">
                                    <div class="form-group row">
                                        <label class="col-sm-2 col-form-label" asp-for="FullNameEn">Name in English</label>
                                        <input type="text" class="col-sm-10 form-control" asp-for="FullNameEn" placeholder="Name In English">
                                        <span class="text-danger" asp-validation-for="FullNameEn"></span>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-sm-2 col-form-label" asp-for="FullNameAr">Name in Arabic</label>
                                        <input type="text" class="col-sm-10 form-control" asp-for="FullNameAr" placeholder="Name In Arabic">
                                        <span class="text-danger" asp-validation-for="FullNameAr"></span>
                                    </div>

                                    <div class="form-group row">
                                        <label class="col-sm-2 col-form-label" asp-for="EmailAddress">Email Address</label>
                                        <input type="text" class="col-sm-10 form-control" asp-for="EmailAddress" placeholder="Email Address">
                                        <span class="text-danger" asp-validation-for="EmailAddress"></span>
                                    </div>
                                </div>
                                <div class="card-footer">
                                    <button type="submit" class="btn btn-info">Submit</button>
                                    <a asp-action="Index" class="btn btn-default float-right">Cancel</a>
                                </div>
                            </form>
                        </div>

                        <!-- /.card-body -->
                    </div>
                    <!-- /.card -->
                </div>
            </div>
            <!-- /.row (main row) -->
        </div><!-- /.container-fluid -->
    </section>
    <!-- /.content -->
</div>

@section Scripts{
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
