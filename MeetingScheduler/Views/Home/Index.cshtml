@using System.Globalization
@model MeetingScheduler.UI.Models.DashboardVm
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer localizer
@using MeetingScheduler.Domain.Enums;
@inject Microsoft.Extensions.Localization.IStringLocalizer<MeetingScheduler.UI.SharedResource> sharedLocalizer
@{
    ViewData["Title"] = localizer["Title"];
}


<style>
    /* SHADE DAYS IN THE PAST */
    td.fc-day.fc-past {
        background-color: #EEEEEE;
    }

    /* Announcement ticker - green background, white text */
    .announcement {
         background: linear-gradient(90deg, #4D5F4F 0%, #576959 100%); /* slightly lighter end stop (#576959) */
        border-bottom: 1px solid #1b5e20;
        padding: 8px 12px;
        overflow: hidden;
        position: relative;
        font-weight: 500;
        color: #fff; /* ensure fallback text color */
    }

    .ticker-wrap {
        overflow: hidden;
        position: relative;
        display: block;
    }

    .ticker {
            width: 100%;
        display: inline-block;
        white-space: nowrap;
        will-change: transform;
        animation: scroll-left 20s linear infinite;
        text-align: center;
    }

    .ticker ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: inline-flex;
        gap: 48px;
        align-items: center;
    }

    .ticker li {
        display: inline-block;
        color: #ffffff; /* announcement text white */
        font-size: 0.95rem;
        line-height: 1.4;
    }

    /* Pause on hover */
    .announcement:hover .ticker {
        animation-play-state: paused;
    }

    .ticker.slow { animation-duration: 30s; }
    .ticker.fast { animation-duration: 12s; }

    /* small fallback for empty */
    .ticker-default {
        color: #e8f5e9;
        font-size: 0.95rem;
    }

    .announcement a {
        color: #e8fbe8;
        text-decoration: underline;
    }

    /* When content is short (single announcement) center it and stop animation */
    .ticker.centered {
        animation: none !important;
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
    }
    .ticker.centered ul {
        display: flex;
        justify-content: center;
        gap: 0;
    }
    .ticker.centered li {
        padding: 0;
    }

</style>


<div class="announcement" role="region" aria-live="polite" aria-label="Announcements">
    <div class="ticker-wrap">
        <div id="ticker" class="ticker">

            <ul>
                    <li>@localizer["Announcement"]</li>
                    
            </ul>

        </div>
    </div>
</div>
<div class="content-header">
