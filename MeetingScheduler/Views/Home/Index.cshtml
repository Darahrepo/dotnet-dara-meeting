<div class="modal fade" data-backdrop="static" data-keyboard="false" id="modal-lg">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="overlay-wrapper">
                <div class="overlay"><i class="fas fa-3x fa-spinner fa-pulse"></i><div class="text-bold pt-2"></div></div>
            </div>
            <div class="modal-header">
                <h4 class="modal-title">
                    @localizer["Details"]
                </h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="@sharedLocalizer["Close"]">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div></div>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-outline-danger btn-default" data-dismiss="modal"> @sharedLocalizer["Close"]</button>
            </div>
        </div>
    </div>
</div>

<script>

    function EventDetails(id,type) {
        $(".overlay").show();
        if ( type === "Meeting") {
            controllerName = "Meeting";
            $.get("@Url.Action("View", "Meeting")/" + id,
                function (data) {
                    $('.modal-body div').html(data);
                    $(".overlay").hide();
                }
            );
        } else if (type === "Webinar") {
            controllerName = "Webinar";
            $.get("@Url.Action("View", "Webinar")/" + id,
                function (data) {
                    $('.modal-body div').html(data);
                    $(".overlay").hide();
                }
             );
        }
    }


  $(function () {

    /* initialize the external events
     -----------------------------------------------------------------*/
    function ini_events(ele) {
      ele.each(function () {

        // create an Event Object (https://fullcalendar.io/docs/event-object)
        // it doesn't need to have a start or end
        var eventObject = {
          title: $.trim($(this).text()) // use the element's text as the event title
        }

        // store the Event Object in the DOM element so we can get to it later
        $(this).data('eventObject', eventObject)

      })
    }

    ini_events($('#external-events div.external-event'))

    /* initialize the calendar
     -----------------------------------------------------------------*/
    //Date for the calendar events (dummy data)
    var date = new Date()
    var d    = date.getDate(),
        m    = date.getMonth(),
        y    = date.getFullYear()

    var Calendar = FullCalendar.Calendar;
    var Draggable = FullCalendar.Draggable;

    var containerEl = document.getElementById('external-events');
    var checkbox = document.getElementById('drop-remove');
    var calendarEl = document.getElementById('calendar');
      var calendar = new Calendar(calendarEl, {
          headerToolbar: {
              left: 'prev,today,next',
              center: 'title',
              right: 'AddMeetingButton',// AddWebinarButton',
          },
          themeSystem: 'bootstrap',
          events: @Html.Raw(Model.CalenderEvents),
          eventOrder: 'backgroundColor,start',
          editable: false,
          droppable: false, // this allows things to be dropped onto the calendar !!!
          businessHours: {
              // days of week. an array of zero-based day of week integers (0=Sunday)
              daysOfWeek: [1, 2, 3, 4, 7], // Monday - Thursday
              startTime: '08:00', // a start time (10am in this example)
              endTime: '20:00', // an end time (6pm in this example)
          },
          eventDidMount: function (info) {
              $(info.el).tooltip({
                  title: info.event._def.title,
                  container: 'body',
                  delay: { "show": 50, "hide": 50 }
              });
          },
          eventClick: function (info) {
              info.jsEvent.preventDefault();
              $(info.el).attr('data-toggle', "modal");
              $(info.el).attr('data-target', "#modal-lg");
              EventDetails(info.event.id, info.event.extendedProps.type);
              info.el.style.borderColor = 'red';
          },
          customButtons: {
              AddMeetingButton: {
                  text: "@localizer["AddMeeting"]",
                  click: function (event, jsEvent, view) {
                      window.location.href = "@Url.Action("Create","Meeting")";
                  },
                  hint: ' @localizer["AddMeeting"]',
                  bootstrapFontAwesome: 'calendar-plus '
              },
              //AddWebinarButton: {
              //    text: "@localizer["AddWebinar"]",
              //    click: function (event, jsEvent, view) {
              //        window.location.href = "@Url.Action("Create","Webinar")";
              //    },
              //    hint: '@localizer["AddWebinar"]',
              //    eventClassNames:"asp-authorize",
              //    bootstrapFontAwesome: 'video'
              //}
          },

      });

      var isArabic = '@CultureInfo.CurrentCulture.TextInfo.IsRightToLeft';

      if(isArabic.toLowerCase() == 'true')
      {
          calendar.setOption('locale', 'ar');
          calendar.setOption('locales', 'arLocale');
          calendar.setOption('direction', 'rtl');
      }
      calendar.render();
  })

    $(function () {
        var Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000
        });



    });

    function changeApprovalStatusInCalendar(e) {
        $(".overlay").show();
        parentElm = e.parentElement.nodeName;
        var reason = $(e).parent(parentElm).siblings(parentElm).find(".reason").val();// $(e).closest('[id]').find('#reason').val();

        var status = $(e).data('status');
        var id = $(e).data('id');


        if (status === "Rejected" && reason == '') {
            toastr.warning(PleaseInsertReason);
            toastr.options.fadeOut = 18000;
            $(".overlay").hide();
        }
        else {
            Swal.fire({
                title: swalTitle,
                icon: "warning",
                html: swalText,
                showCancelButton: true,
                confirmButtonText: swalConfirmButtonText,
                cancelButtonText: swalCancelButtonText,
            }).then(function (result) {
                if (result.value) {
                    $.ajax({ //Submit the value of the drop_down
                        url: "/" + controllerName + "/ChangeApprovalStatus/",
                        type: "post",
                        data: { id: id, reason: reason, status: status },
                        success: function (response) {
                            if (response.type == 'success') {
                                $(".overlay").hide();
                                location.reload();
                            } else {
                                toastr[response.type](response.message);
                                toastr.options.fadeOut = 18000;
                            }
                            $(".overlay").hide();
                        }, error: function (response) {
                            $(".overlay").hide();
                            location.reload();
                        }
                    });
                } else {
                    // handle cancel
                    $(".overlay").hide();
                }
            });
        }
    }
</script>