<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd" 
	  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
	  autoReload="true" 
	  internalLogLevel="info" 
	  internalLogFile=".\logs\internalLog.txt">
	<extensions>
		<add assembly="NLog.Web.AspNetCore" />
	</extensions>
	 <!--the targets to write to--> 
	<targets>
		 <!--write to file--> 
		<target xsi:type="File" name="alldata" 
				fileName=".\logs\${date:format=yyyy-MM-dd}\${date:format=yyyy-MM-dd HH_mm}.log" 
				layout=" *********${level}(${longdate}) ${machinename}   ********   
							${newline} ${newline}      
							Exception Type:   ${level}${newline}      
							Exception Message:    ${exception}${newline}      
							Stack Trace:          ${stacktrace}${newline}      
							Additional Info:     ${message}${newline}"
				/>
		 <!--another file log. Uses some ASP.NET core renderers--> 
	</targets>
	 <!--rules to map from logger name to target--> 
	<rules>
		<logger name="*" minlevel="Error" writeTo="alldata" />
		<!--Skip non-critical Microsoft logs and so log only own logs-->
		<!--<logger name="Microsoft.*" maxLevel="Trace" final="true" />-->
		<!--<logger name= "*" minlevel="Trace" writeTo="otherFile-web" />-->
	</rules>
</nlog>

